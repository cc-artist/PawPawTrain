PORT=8082

# MySQL (optional for demo)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pawtrain

# Redis (optional for demo)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 豆包 (Doubao) - 字节跳动AI，使用方舟Ark API
# API Key从火山引擎控制台获取: https://console.volcengine.com/ark
# 支持 Seedream 5.0 图像生成模型
ARK_API_KEY=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 文心一言 (ERNIE) - 百度AI
ERNIE_API_KEY=
ERNIE_SECRET_KEY=

# Stability AI
STABILITY_API_KEY=

# Hugging Face
HUGGING_FACE_API_KEY=

# Baidu AI Image Recognition
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# JWT
JWT_SECRET=your-jwt-secret-key

# Cloudinary配置 (图片云存储)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# 图片生成默认模型 (可选: openai, doubao, ernie, stability, huggingface)
DEFAULT_IMAGE_MODEL=doubao
